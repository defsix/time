# Generated by XcodeGen (`xcodegen generate`) from project.yml — not committed
# so the project file never conflicts or drifts from the spec.
*.xcodeproj

# Xcode user state / build products
xcuserdata/
DerivedData/
*.xcuserstate
*.xcworkspace

# Synced from the web app's build output by Scripts/sync-web-assets.sh;
# regenerated on every build, not hand-edited or committed. The directory
# itself (via .gitkeep) stays tracked so `xcodegen generate` has a source
# directory to find on a fresh checkout, before that script has run.
WorldTime/Resources/www/*
!WorldTime/Resources/www/.gitkeep
