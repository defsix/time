# Copy this file to keystore.properties (gitignored) and fill in the real
# values to produce a properly-signed release build/AAB locally, e.g. for
# uploading to the Play Console. See android/README.md > "Play Store release
# signing" for how to generate a keystore.
storeFile=/absolute/path/to/release.jks
storePassword=changeme
keyAlias=world-time-release
keyPassword=changeme
